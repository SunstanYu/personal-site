---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleListItem from '../components/ArticleListItem.astro';

const posts = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const url = new URL(Astro.request.url);
const activeTag = url.searchParams.get('tag') || undefined;
const activeLang = url.searchParams.get('lang') || undefined;

const filtered = posts.filter((p) => {
  if (activeTag && !p.data.tags.includes(activeTag)) return false;
  if (activeLang && p.data.lang !== activeLang) return false;
  return true;
});

const tags = Array.from(new Set(posts.flatMap((p) => p.data.tags))).sort();
---

<BaseLayout title="Writing — Charles" current="writing" tags={tags} activeTag={activeTag}>
  <header class="page-head">
    <h1>Writing</h1>
    <p class="sub">技术笔记、项目记录与一些随想。</p>
  </header>

  <div class="tag-filter">
    <a href="/" class={!activeTag ? 'active' : ''}>All</a>
    {tags.map((t) => (
      <a
        href={`/?tag=${encodeURIComponent(t)}`}
        class={activeTag === t ? 'active' : ''}
      >#{t}</a>
    ))}
  </div>

  <div class="article-list">
    {filtered.map((post) => (
      <ArticleListItem
        href={`/writing/${post.slug}`}
        title={post.data.title}
        date={post.data.date}
        lang={post.data.lang}
        description={post.data.description}
        tags={post.data.tags}
        body={post.body}
        readingMinutes={post.data.readingTime}
      />
    ))}
    {filtered.length === 0 && (
      <p style="color: var(--color-text-tertiary); padding: 24px 0;">No posts match the current filter.</p>
    )}
  </div>
</BaseLayout>
