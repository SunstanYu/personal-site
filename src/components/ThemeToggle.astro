---
// Theme toggle button. Click wiring lives in BaseLayout so it only runs
// once per page even when this component is rendered in both Sidebar
// and TopNav.
---

<button
  class="icon-btn theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  data-theme-toggle
>
  <i class="ti ti-moon" data-theme-icon-light aria-hidden="true"></i>
  <i class="ti ti-sun" data-theme-icon-dark aria-hidden="true" style="display:none"></i>
</button>
